# Merged backend (api/) -- recruiter ranking + candidate/interview routes run
# as one FastAPI app (api_service.py). Copy to api/.env and fill in.

# Supabase project (server-side: use the SERVICE ROLE key, not the anon key --
# the backend writes across users and must bypass RLS).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# LLM key. FOOTGUN: process_resumes.py reads os.getenv("OPENAI_API_KEY") and
# points the OpenAI client at Groq's OpenAI-compatible endpoint
# (base_url=https://api.groq.com/openai/v1). So despite the name, this must
# hold a **Groq** API key, not an OpenAI one.
OPENAI_API_KEY=your-groq-api-key

# Same Groq key, under its real name -- the candidate/interview routes
# (student/core/*_service.py) use the native Groq client directly instead of
# the OpenAI-compatible shim above, so both env vars must be set and can hold
# the same value.
GROQ_API_KEY=your-groq-api-key

# Comma-separated list of origins allowed to call this API, e.g.
# "https://your-app.vercel.app,http://localhost:3000". Defaults to localhost
# only if unset -- set this to your deployed frontend's real origin, or the
# production frontend will be blocked by CORS.
ALLOWED_ORIGINS=http://localhost:3000
