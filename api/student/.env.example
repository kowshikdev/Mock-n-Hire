# Candidate / interview backend (api/student/) -- copy to api/student/.env and fill in.

# Supabase project (server-side: SERVICE ROLE key).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# Groq API key -- chat completions (question generation, answer scoring) and
# Whisper transcription. This backend reads GROQ_API_KEY directly (unlike the
# recruiter backend, which reuses OPENAI_API_KEY for the same Groq key).
GROQ_API_KEY=your-groq-api-key
