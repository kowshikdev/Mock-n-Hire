# Monorepo root .gitignore
# Layout: ui/ (Next.js frontend), api/ (FastAPI backend), assets/ (images)
# Patterns are intentionally un-rooted so they match inside ui/ and api/.

# ---- Node / Next.js (ui/) ----
node_modules/
.pnp
.pnp.js
.next/
out/
build/
coverage/
*.tsbuildinfo
next-env.d.ts

# ---- Python (api/) ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# ---- Local runtime artifacts (api/ generates these at cwd) ----
api/resumes/
api/uploads/
api/processed_data/

# ---- Env files ----
.env
.env*.local
.envlocal

# ---- Misc ----
.DS_Store
*.pem
*.exe
*.zip
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- Vercel ----
.vercel
