# Frontend (ui/) -- copy to ui/.env.local and fill in.
# These are also the two environment variables you must set in Vercel
# (Project -> Settings -> Environment Variables) for the production build.
#
# NEXT_PUBLIC_* values are exposed to the browser by design -- use the
# publishable ANON key here, never the service-role key.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
